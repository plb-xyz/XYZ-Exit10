{
  "version": "1.4",
  "globalModes": ["INITIALIZING", "NORMAL", "SHOW", "FAULT"],

  "context": {
    "mode": "INITIALIZING",

    "schedulerEnabled": false,

    "prayer": {
      "active": false,
      "endsAt": null,
      "volumeDeltaDb": -10,
      "pendingShow": null
    },

    "show": {
      "active": false,
      "showId": null,
      "requestedBy": null,
      "requestedAt": null
    },

    "event": {
      "active": false,
      "type": "NONE",
      "scope": null,
      "presetId": null,
      "startedAt": null,
      "requestedBy": null
    },

    "audio": {
      "notes": [
        "Playback domains control which audio source is selected for each physical zone group.",
        "Supported selections — inside: SHOW | BGM | SPECIAL | NONE; landscape: SHOW | BGM | NONE.",
        "SPECIAL playback is inside-only; the landscape domain must never be set to SPECIAL.",
        "BGM is delivered via Watchout timelines (bg_music_1..bg_music_4) on channels 3–4.",
        "SPECIAL playback comes from Watchout channels 1–2 (inside spaces only).",
        "SHOW playback comes from Watchout channels 5–64.",
        "RULE: When context.mode == 'SHOW', both domains' effective playback is forced to 'SHOW' regardless of desired value."
      ],
      "domains": {
        "inside": {
          "desired": "BGM",
          "effective": "BGM",
          "bgmSelection": "bg_music_1",
          "specialSelection": null,
          "transition": {
            "fadeOutMs": 2000,
            "fadeInMs": 2000,
            "mode": "CROSS_FADE"
          }
        },
        "landscape": {
          "notes": ["SPECIAL is not a valid selection for the landscape domain."],
          "desired": "BGM",
          "effective": "BGM",
          "bgmSelection": "bg_music_1",
          "transition": {
            "fadeOutMs": 2000,
            "fadeInMs": 2000,
            "mode": "CROSS_FADE"
          }
        }
      }
    },

    "spaces": {
      "a1": {
        "capabilities": { "hasVideo": true },
        "background": { "type": "AMBIENCE", "contentId": null },
        "special": {
          "onTop": { "active": false, "contentId": null, "audioMode": "none" },
          "fullscreen": {
            "active": false,
            "contentId": null,
            "audioMode": "none",
            "includes": { "ribbon": true, "column": true, "sphere": false }
          }
        },
        "audio": {
          "playbackDomain": "inside",
          "playback": {
            "enabled": true,
            "levelsDb": { "bgm": 0, "show": 0, "special": 0 }
          },
          "live": {
            "mics": {
              "mic1": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" },
              "mic2": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" }
            },
            "mixer": {
              "enabled": false,
              "mode": "GLOBAL",
              "mixerId": null,
              "levelDb": 0,
              "outputPresetId": "all_speakers"
            }
          },
          "ducking": {
            "enabled": true,
            "triggerSources": ["mic1", "mic2"],
            "duckTargets": ["playback"],
            "duckAmountDb": -12,
            "attackMs": 100,
            "releaseMs": 500
          }
        }
      },
      "a2": {
        "capabilities": { "hasVideo": true },
        "background": { "type": "AMBIENCE", "contentId": null },
        "special": {
          "onTop": { "active": false, "contentId": null, "audioMode": "none" },
          "fullscreen": {
            "active": false,
            "contentId": null,
            "audioMode": "none",
            "includes": { "ribbon": true, "column": true, "sphere": false }
          }
        },
        "audio": {
          "playbackDomain": "inside",
          "playback": {
            "enabled": true,
            "levelsDb": { "bgm": 0, "show": 0, "special": 0 }
          },
          "live": {
            "mics": {
              "mic1": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" },
              "mic2": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" }
            },
            "mixer": {
              "enabled": false,
              "mode": "GLOBAL",
              "mixerId": null,
              "levelDb": 0,
              "outputPresetId": "all_speakers"
            }
          },
          "ducking": {
            "enabled": true,
            "triggerSources": ["mic1", "mic2"],
            "duckTargets": ["playback"],
            "duckAmountDb": -12,
            "attackMs": 100,
            "releaseMs": 500
          }
        }
      },
      "a3": {
        "capabilities": { "hasVideo": true },
        "background": { "type": "AMBIENCE", "contentId": null },
        "special": {
          "onTop": { "active": false, "contentId": null, "audioMode": "none" },
          "fullscreen": {
            "active": false,
            "contentId": null,
            "audioMode": "none",
            "includes": { "ribbon": true, "column": true, "sphere": false }
          }
        },
        "audio": {
          "playbackDomain": "inside",
          "playback": {
            "enabled": true,
            "levelsDb": { "bgm": 0, "show": 0, "special": 0 }
          },
          "live": {
            "mics": {
              "mic1": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" },
              "mic2": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" }
            },
            "mixer": {
              "enabled": false,
              "mode": "GLOBAL",
              "mixerId": null,
              "levelDb": 0,
              "outputPresetId": "all_speakers"
            }
          },
          "ducking": {
            "enabled": true,
            "triggerSources": ["mic1", "mic2"],
            "duckTargets": ["playback"],
            "duckAmountDb": -12,
            "attackMs": 100,
            "releaseMs": 500
          }
        }
      },
      "ls": {
        "capabilities": { "hasVideo": false },
        "background": { "type": "AUDIO_LIGHTING_ONLY" },
        "special": {
          "onTop": { "active": false, "contentId": null, "audioMode": "none" },
          "fullscreen": {
            "active": false,
            "contentId": null,
            "audioMode": "none",
            "includes": { "ribbon": false, "column": false, "sphere": false }
          }
        },
        "audio": {
          "playbackDomain": "landscape",
          "playback": {
            "enabled": true,
            "levelsDb": { "bgm": 0, "show": 0 },
            "notes": ["'special' level is intentionally absent: SPECIAL playback is not valid in the landscape domain."]
          },
          "live": {
            "mics": {
              "mic1": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" },
              "mic2": { "enabled": false, "levelDb": 0, "outputPresetId": "all_speakers" }
            },
            "mixer": {
              "enabled": false,
              "mode": "GLOBAL",
              "mixerId": null,
              "levelDb": 0,
              "outputPresetId": "all_speakers"
            }
          },
          "ducking": {
            "enabled": true,
            "triggerSources": ["mic1", "mic2"],
            "duckTargets": ["playback"],
            "duckAmountDb": -12,
            "attackMs": 100,
            "releaseMs": 500
          }
        }
      }
    }
  },

  "subModes": {
    "NORMAL": {
      "event": ["NONE", "SIMPLE", "COMPLEX"],
      "spaceLayering": ["BACKGROUND", "SPECIAL_ON_TOP", "SPECIAL_FULLSCREEN"],
      "notes": [
        "Ambiences are per-space background content (A1/A2/A3 video+audio+lighting; LS audio+lighting only).",
        "Events are sub-mode overrides inside NORMAL; scheduler is disabled during events.",
        "Simple events may be audio+lighting only (video stays as ambience unless explicitly overridden).",
        "Complex events may include space takeover (video+audio+lighting) and live operation."
      ]
    },
    "SHOW": {
      "notes": [
        "Show is global (all spaces), timecode-synced, controls external systems.",
        "No show may start during prayer.active=true.",
        "If prayer becomes active while SHOW is running: abort immediately with fade-out, then return to NORMAL."
      ]
    }
  },

  "inputs": {
    "system": ["sys/ready", "sys/fault", "sys/resetFault"],

    "ui": [
      "ui/startShow",
      "ui/abortShow",

      "ui/setAmbience",
      "ui/clearAmbience",

      "ui/startEventSimple",
      "ui/startEventComplex",
      "ui/endEvent",

      "ui/specialFullscreenOn",
      "ui/specialFullscreenOff",
      "ui/specialOnTopOn",
      "ui/specialOnTopOff"
    ],

    "scheduler_future": [
      "sched/startShow",
      "sched/startEventSimple",
      "sched/startEventComplex",
      "sched/setAmbience"
    ],

    "prayer": ["prayer/active", "prayer/inactive"],

    "feedback": ["wo/state", "ma/status", "qsys/status"]
  },

  "guards": [
    {
      "id": "block-show-during-prayer",
      "when": "startShow",
      "allow": "context.prayer.active == false"
    },
    {
      "id": "block-show-during-event",
      "when": "startShow",
      "allow": "context.event.active == false"
    }
  ],

  "derived": [
    {
      "id": "schedulerEnabled-default",
      "compute": "context.schedulerEnabled = (context.mode == 'NORMAL' && context.event.active == false && context.prayer.active == false)"
    }
  ],

  "payloadConventions": {
    "specialContentSpacesField": {
      "preferredName": "spaces",
      "legacyName": "targets",
      "note": "Use 'spaces' (array of space IDs) for ui/specialOnTopOn and ui/specialFullscreenOn payloads. The Decision Maker also accepts the legacy name 'targets' for backward compatibility during transition.",
      "example": {
        "topic": "ui/specialOnTopOn",
        "payload": {
          "spaces": ["a1"],
          "contentId": "promo_overlay_16x9",
          "audioMode": "duckBG"
        }
      }
    }
  },

  "policies": {
    "landscape": {
      "video": "NONE",
      "audioLightingOnly": true,
      "notes": [
        "Do not send Watchout video timeline commands for LS.",
        "LS can still participate in SHOW audio and lighting behavior (project policy)."
      ]
    },
    "prayer": {
      "showDuringPrayer": "BLOCK_AND_POSTPONE",
      "postponeOffsetMs": 60000,
      "showIfPrayerStartsMidShow": "ABORT_IMMEDIATELY_WITH_FADE_OUT",
      "volumeControl": "QSYS_GLOBAL_TRIM_DB"
    }
  }
}
