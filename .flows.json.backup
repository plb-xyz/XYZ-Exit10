    {
        "id": "wo2-discover-http",
        "type": "http request",
        "z": "wo2-tab",
        "name": "GET /v0/timelines",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 510,
        "y": 320,
        "wires": [
            [
                "wo2-discover-parse-fn"
            ]
        ]
    },
    {
        "id": "wo2-discover-parse-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Parse timelines response",
        "func": "// Parse GET /v0/timelines response and build diff\n\nif (msg.statusCode !== 200) {\n    msg.payload = { status: 'error', error: 'Watchout returned HTTP ' + (msg.statusCode || 'unknown') };\n    return msg;\n}\n\nfunction parseTimelineName(name) {\n    if (!name || name.startsWith('_')) return null;\n    return name.trim().toLowerCase().replace(/\\s+/g, '_').replace(/[^a-z0-9_]/g, '');\n}\n\nfunction compareMapping(oldMap, newMap) {\n    const oldKeys = Object.keys(oldMap);\n    const newKeys = Object.keys(newMap);\n    return {\n        removed:   oldKeys.filter(k => !(k in newMap)),\n        added:     newKeys.filter(k => !(k in oldMap)),\n        unchanged: oldKeys.filter(k => (k in newMap) && oldMap[k] === newMap[k]),\n        changed:   oldKeys.filter(k => (k in newMap) && oldMap[k] !== newMap[k]),\n    };\n}\n\nfunction formatDiff(diff) {\n    const lines = [];\n    diff.removed.forEach(n   => lines.push(\"REMOVED  : Timeline '\" + n + \"' no longer exists\"));\n    diff.added.forEach(n     => lines.push(\"ADDED    : New timeline '\" + n + \"' discovered\"));\n    diff.changed.forEach(n   => lines.push(\"CHANGED  : Timeline '\" + n + \"' ID has changed\"));\n    diff.unchanged.forEach(n   => lines.push(\"OK       : '\" + n + \"'\"));\n    return lines;\n}\n\nconst timelines = Array.isArray(msg.payload) ? msg.payload : [];\n\nconst newMapping = {};\ntimelines.forEach(tl => {\n    const contentId = parseTimelineName(tl.name);\n    if (contentId) newMapping[contentId] = String(tl.id);\n});\n\nconst storedMapping = flow.get('watchout_mapping') || {};\nconst diff     = compareMapping(storedMapping, newMapping);\nconst diffLines = formatDiff(diff);\n\nflow.set('watchout_pending', newMapping);\n\nconst count = Object.keys(newMapping).length;\nnode.status({ fill: 'green', shape: 'dot', text: 'Discovered: ' + count + ' timelines' });\n\nmsg.payload = { status: 'discovered', count, diffLines, newMapping, diff };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 320,
        "wires": [
            [
                "wo2-diff-template",
                "wo2-debug-disc"
            ]
        ]
    },
    {
        "id": "wo2-control-http",
        "type": "http request",
        "z": "wo2-tab",
        "g": "dbd2c45c3962d1cd",
        "name": "Watchout API call",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 670,
        "y": 640,
        "wires": [
            [
                "wo2-control-format-fn"
            ]
        ]
    },
    {
        "id": "wo2-control-format-fn",
        "type": "function",
        "z": "wo2-tab",
        "g": "dbd2c45c3962d1cd",
        "name": "Format control response",
        "func": "// Normalize the Watchout API response into a uniform JSON object\nconst command    = msg._command;\nconst timelineId = msg._timelineId;\nconst statusCode = msg.statusCode || 200;\n\nmsg.payload    = JSON.stringify({\n    success:    statusCode < 300,\n    command:    command,\n    timelineId: timelineId,\n    statusCode: statusCode,\n    body:       msg.payload\n});\nmsg.statusCode = 200;\nmsg.headers    = { 'Content-Type': 'application/json' };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 900,
        "y": 640,
        "wires": [
            [
                "wo2-control-resp"
            ]
        ]
    },
    {
        "id": "wo2-sse-event-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Process SSE event",
        "func": "// Process an incoming SSE event from the Watchout SSE client node.\n// msg.payload = event data (auto-parsed JSON if possible)\n// msg.event   = event type string\n\nconst wasConnected = flow.get('watchout_sse_status') === 'connected';\n\nconst event = {\n    type: msg.event || 'message',\n    data: msg.payload\n};\n\nflow.set('watchout_state',      event.data || event);\nflow.set('watchout_sse_status', 'connected');\n\n// Output 1: state event for Live State UI\nconst stateMsg  = { payload: event, topic: 'watchout/state' };\n\n// Output 2: SSE status update (only send once on initial connect)\nconst statusMsg = wasConnected ? null\n    : { payload: { status: 'sse_connected' } };\n\nnode.send([stateMsg, statusMsg]);\nreturn null;",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 780,
        "wires": [
            [
                "wo2-state-template"
            ],
            [
                "wo2-sse-status-template"
            ]
        ]
    },
    {
        "id": "wo2-sse-catch",
        "type": "catch",
        "z": "wo2-tab",
        "name": "SSE error",
        "scope": [
            "wo2-sse-node"
        ],
        "uncaught": false,
        "x": 590,
        "y": 840,
        "wires": [
            [
                "wo2-sse-error-fn"
            ]
        ]
    },
    {
        "id": "wo2-sse-error-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "SSE error handler",
        "func": "// Handle SSE connection errors / disconnects\nflow.set('watchout_sse_status', 'error');\nconst errMsg = (msg.error && msg.error.message) ? msg.error.message : String(msg.error || 'SSE error');\nnode.send({ payload: { status: 'sse_error', message: errMsg } });\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 840,
        "wires": [
            [
                "wo2-sse-status-template"
            ]
        ]
    },
    {
        "id": "wo2-poll-http",
        "type": "http request",
        "z": "wo2-tab",
        "name": "GET /v0/state",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
