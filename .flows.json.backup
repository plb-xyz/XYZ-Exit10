    {
        "id": "wo2-discover-btn",
        "type": "ui-button",
        "z": "wo2-tab",
        "group": "20eba16b1f4b5a48",
        "name": "Re-discover Timelines",
        "label": "Re-discover Timelines",
        "order": 1,
        "width": "0",
        "height": "0",
        "emulateClick": false,
        "tooltip": "Fetch timeline list from Watchout and check for changes",
        "className": "",
        "icon": "",
        "iconPosition": "left",
        "payload": "",
        "payloadType": "date",
        "topic": "",
        "topicType": "str",
        "buttonColor": "",
        "textColor": "",
        "iconColor": "",
        "enableClick": true,
        "enablePointerdown": false,
        "pointerdownPayload": "",
        "pointerdownPayloadType": "str",
