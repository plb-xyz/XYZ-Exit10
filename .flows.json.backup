    {
        "id": "ma-d2-seq-cue-fn",
        "type": "function",
        "z": "ma-tab",
        "name": "goSequenceCue",
        "func": "'use strict';\nvar seq = global.get('ma_seq_id');\nif (seq == null) seq = 1;\nvar cue = global.get('ma_seq_cue');\nif (cue == null) cue = 1;\nmsg.payload = { action: 'goSequenceCue', sequence: seq, cue: cue };\nreturn msg;",
        "outputs": 1,
        "x": 420,
        "y": 1280,
        "wires": [
            [
                "ma-control-fn"
            ]
        ]
    },
    {
        "id": "ma-d2-seq-sent-dbg",
