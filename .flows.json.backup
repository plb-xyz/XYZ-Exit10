    {
        "id": "wo2-diff-template",
        "type": "ui-template",
        "z": "4427b69f42325844",
        "group": "f4d4b5c1c3b0a1ae",
        "name": "Timeline Diff",
        "order": 2,
        "width": 12,
        "height": 8,
        "head": "",
        "format": "<template>\n  <div class=\"wo-panel\" v-if=\"p && p.status === 'diff_ready'\">\n    <div class=\"wo-title\">Timeline Discovery — Review Changes</div>\n    <div class=\"wo-info\">\n      Found {{p.diff.removed.length}} removed,\n      {{p.diff.added.length}} added,\n      {{p.diff.changed.length}} changed,\n      {{p.diff.unchanged.length}} unchanged.\n    </div>\n\n    <div v-for=\"(line, idx) in p.diffLines\" :key=\"idx\" class=\"wo-line\" :class=\"lineClass(line)\">\n      {{ line }}\n    </div>\n\n    <div class=\"wo-hint\">\n      Use the Confirm/Cancel buttons above to save or discard the pending mapping.\n    </div>\n  </div>\n\n  <div class=\"wo-panel\" v-else-if=\"p && p.status === 'no_changes'\">\n    <div class=\"wo-title\">Timeline Discovery</div>\n    <div class=\"wo-ok\">✓ No changes detected. Mapping is up to date.</div>\n  </div>\n\n  <div class=\"wo-panel\" v-else-if=\"p && p.status === 'error'\">\n    <div class=\"wo-title wo-err\">Discovery Error</div>\n    <div>{{ p.error }}</div>\n  </div>\n\n  <div class=\"wo-panel\" v-else>\n    <div class=\"wo-title\">Timeline Discovery</div>\n    <div class=\"wo-muted\">Click “Re-discover Timelines” to compare Watchout timelines with your stored mapping.</div>\n  </div>\n</template>\n\n<script>\nexport default {\n  computed: {\n    p () { return this.msg?.payload }\n  },\n  methods: {\n    lineClass (line) {\n      if (!line) return ''\n      if (line.startsWith('❌')) return 'wo-removed'\n      if (line.startsWith('✨')) return 'wo-added'\n      if (line.startsWith('🔄')) return 'wo-changed'\n      if (line.startsWith('✓'))  return 'wo-unchanged'\n      return ''\n    }\n  }\n}\n</script>\n\n<style>\n.wo-panel { font-family: monospace; padding: 12px; }\n.wo-title { font-size: 16px; font-weight: bold; margin-bottom: 8px; color: #333; }\n.wo-line  { padding: 2px 0; white-space: pre; }\n.wo-removed   { color: #d32f2f; }\n.wo-added     { color: #2e7d32; }\n.wo-changed   { color: #e65100; }\n.wo-unchanged { color: #616161; }\n.wo-info { color: #1565c0; font-style: italic; margin-bottom: 6px; }\n.wo-ok { color: #2e7d32; }\n.wo-err { color: #d32f2f; }\n.wo-muted { color: #777; }\n.wo-hint { margin-top: 10px; color:#555; font-style: italic; }\n</style>",
        "storeOutMessages": false,
        "passthru": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 570,
        "y": 160,
        "wires": [
            []
        ]
    },
    {
        "id": "wo2-status-template",
        "type": "ui-template",
        "z": "4427b69f42325844",
        "group": "ef07ffba08e94be9",
        "name": "Mapping Status",
        "order": 1,
        "width": 12,
        "height": 6,
        "head": "",
        "format": "<template>\n  <div class=\"wo-status\">\n    <div v-if=\"p && p.status === 'saved'\">\n      <div class=\"wo-ok\">✔ Mapping saved at {{ p.savedAt }}</div>\n      <div class=\"wo-mapping\" v-if=\"p.mapping\">\n        <div v-for=\"(v,k) in p.mapping\" :key=\"k\" class=\"wo-row\">\n          <span class=\"wo-key\">{{k}}</span>\n          <span class=\"wo-val\">→ ID {{v}}</span>\n        </div>\n      </div>\n    </div>\n\n    <div v-else-if=\"p && p.status === 'cancelled'\" class=\"wo-muted\">\n      Discovery cancelled. No changes saved.\n    </div>\n\n    <div v-else-if=\"p && p.status === 'nothing_pending'\" class=\"wo-muted\">\n      Nothing to confirm. Run discovery first.\n    </div>\n\n    <div v-else-if=\"p && p.status === 'error'\" class=\"wo-err\">\n      ❌ Error: {{ p.error }}\n    </div>\n\n    <div v-else class=\"wo-muted\">\n      No status yet.\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  computed: {\n    p () { return this.msg?.payload }\n  }\n}\n</script>\n\n<style>\n.wo-status { font-family: monospace; padding: 12px; }\n.wo-ok { color: #2e7d32; font-weight: bold; }\n.wo-err { color: #d32f2f; font-weight: bold; }\n.wo-muted { color: #616161; }\n.wo-row { display:flex; gap:16px; padding: 2px 0; }\n.wo-key { font-weight: bold; min-width: 140px; }\n.wo-val { color: #555; }\n.wo-mapping { margin-top: 8px; }\n</style>",
        "storeOutMessages": false,
        "passthru": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 800,
        "y": 500,
        "wires": [
            []
        ]
    },
    {
        "id": "wo2-state-template",
        "type": "ui-template",
        "z": "4427b69f42325844",
        "group": "dfba414e3e61e11b",
        "name": "Live State",
        "order": 1,
        "width": 12,
        "height": 6,
        "head": "",
        "format": "<template>\n  <div class=\"wo-state\">\n    <div v-if=\"p && p.type === 'connected'\" class=\"wo-ok\">● Connected (SSE)</div>\n    <div v-else-if=\"p && p.type === 'disconnected'\" class=\"wo-err\">○ Disconnected — polling every 5 s</div>\n\n    <pre v-if=\"p && p.data\">{{ pretty(p.data) }}</pre>\n    <pre v-else-if=\"p\">{{ pretty(p) }}</pre>\n    <div v-else class=\"wo-muted\">No data yet.</div>\n  </div>\n</template>\n\n<script>\nexport default {\n  computed: { p () { return this.msg?.payload } },\n  methods: {\n    pretty (o) {\n      try { return JSON.stringify(o, null, 2) } catch (e) { return String(o) }\n    }\n  }\n}\n</script>\n\n<style>\n.wo-state { font-family: monospace; padding: 12px; font-size: 13px; }\n.wo-state pre { background:#f5f5f5; padding:8px; border-radius:4px; overflow:auto; white-space: pre-wrap; }\n.wo-ok { color: #2e7d32; font-weight: bold; }\n.wo-err { color: #d32f2f; font-weight: bold; }\n.wo-muted { color: #777; }\n</style>",
        "storeOutMessages": false,
        "passthru": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 620,
        "y": 380,
        "wires": [
            []
        ]
    },
    {
        "id": "ma-init-inj",
        "type": "inject",
        "z": "ma-tab",
        "name": "Init MA config on deploy",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "str",
        "x": 160,
        "y": 60,
        "wires": [
            [
                "ma-init-fn"
            ]
        ]
    },
    {
        "id": "ma-init-fn",
        "type": "function",
        "z": "ma-tab",
        "name": "MA Init (load config + set globals)",
        "func": "'use strict';\nvar fs   = require('fs');\nvar path = require('path');\nvar userDir = (typeof RED !== 'undefined' && RED.settings && RED.settings.userDir)\n    ? RED.settings.userDir : process.cwd();\n\nfunction findConfigPath(dir) {\n    var tried = [];\n    try {\n        var projDir = path.join(dir, 'projects');\n        var projects = fs.readdirSync(projDir);\n        for (var i = 0; i < projects.length; i++) {\n            var p = path.join(projDir, projects[i], 'node-red', 'config', 'ma-config.json');\n            tried.push(p);\n            if (fs.existsSync(p)) return { path: p, tried: tried };\n        }\n    } catch(e) {\n        if (e.code !== 'ENOENT' && e.code !== 'ENOTDIR') {\n            node.warn('[MA Init] projects dir scan: ' + e.message);\n        }\n    }\n    var p2 = path.join(dir, 'node-red', 'config', 'ma-config.json');\n    tried.push(p2);\n    if (fs.existsSync(p2)) return { path: p2, tried: tried };\n    var p3 = path.join(dir, 'config', 'ma-config.json');\n    tried.push(p3);\n    if (fs.existsSync(p3)) return { path: p3, tried: tried };\n    return { path: null, tried: tried };\n}\n\nvar found = findConfigPath(userDir);\nif (!found.path) {\n    node.error('[MA Init] ma-config.json not found. Tried: ' + found.tried.join(', '));\n    return { topic: 'ma/init/error', payload: { error: 'ma-config.json not found', attempted: found.tried } };\n}\nvar configPath = found.path;\nvar config;\ntry {\n    config = JSON.parse(fs.readFileSync(configPath, 'utf8'));\n} catch (err) {\n    node.error('[MA Init] Failed to read config from ' + configPath + ': ' + err.message);\n    return { topic: 'ma/init/error', payload: { error: err.message, path: configPath } };\n}\nglobal.set('ma_config', config);\nif (global.get('ma_owner') === undefined) {\n    global.set('ma_owner', null);\n    global.set('ma_owner_setBy', 'ma-init');\n}\nif (!global.get('ma_zones')) global.set('ma_zones', { a1: false, a2: false, a3: false, ls: false });\nif (global.get('ma_exec_cue') === undefined) global.set('ma_exec_cue', 1);\nif (global.get('ma_seq_id')   === undefined) global.set('ma_seq_id',   1);\nif (global.get('ma_seq_cue')  === undefined) global.set('ma_seq_cue',  1);\nvar owner = global.get('ma_owner');\nvar setBy = global.get('ma_owner_setBy');\nvar zones = Object.keys((config.zoneExecutor || {})).join(', ');\nnode.log('[MA Init] Config loaded from ' + configPath + '. Zones: ' + zones + '. Owner: ' + owner);\nreturn { topic: 'ma/init', payload: { config: config, owner: owner, setBy: setBy, message: 'MA config loaded. Zones: ' + zones + '. Owner: ' + owner } };",
        "outputs": 1,
        "x": 440,
        "y": 60,
        "wires": [
            [
                "ma-d2-owner-dbg"
            ]
        ]
    },
