    {
        "id": "8b9aee18b610f4ad",
        "type": "ui-template",
        "z": "19fbd7cf3882c4ad",
        "d": true,
        "group": "8ad5a7c72deac7fb",
        "page": "",
        "ui": "",
        "name": "",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div v-if=\"visible\" class=\"nr-modal-backdrop\" @click.self=\"cancel\">\n    <div class=\"nr-modal\" role=\"dialog\" aria-modal=\"true\" :aria-label=\"title\">\n      <div class=\"nr-modal-header\">\n        <div class=\"nr-modal-title\">{{ title }}</div>\n      </div>\n\n      <div class=\"nr-modal-body\">\n        <div class=\"nr-modal-message\" v-html=\"message\"></div>\n      </div>\n\n      <div class=\"nr-modal-actions\">\n        <button class=\"nr-btn nr-btn-cancel\" @click=\"cancel\">\n          {{ cancelText }}\n        </button>\n        <button class=\"nr-btn nr-btn-confirm\" @click=\"confirm\">\n          {{ confirmText }}\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      visible: false,\n      title: \"Confirm\",\n      message: \"Are you sure?\",\n      confirmText: \"Confirm\",\n      cancelText: \"Cancel\",\n      actionId: null,\n    };\n  },\n  methods: {\n    open(payload) {\n      this.title = payload?.title ?? \"Confirm\";\n      this.message = payload?.message ?? \"Are you sure?\";\n      this.confirmText = payload?.confirmText ?? \"Confirm\";\n      this.cancelText = payload?.cancelText ?? \"Cancel\";\n      this.actionId = payload?.actionId ?? null;\n      this.visible = true;\n    },\n    close() {\n      this.visible = false;\n    },\n    confirm() {\n      this.$emit(\"send\", { payload: { actionId: this.actionId, choice: \"confirm\" } });\n      this.close();\n    },\n    cancel() {\n      this.$emit(\"send\", { payload: { actionId: this.actionId, choice: \"cancel\" } });\n      this.close();\n    },\n  },\n  mounted() {\n    // Dashboard 2 pushes msg updates into the component; `this.msg` is reactive\n    // We'll watch for \"open\" messages.\n    this.$watch(\n      () => this.msg,\n      (msg) => {\n        const p = msg?.payload;\n        if (p && p.open === true) this.open(p);\n        if (p && p.open === false) this.close();\n      },\n      { deep: true }\n    );\n  },\n};\n</script>\n\n<style>\n/* Backdrop */\n.nr-modal-backdrop {\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,0.65);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 9999;\n  padding: 24px;\n}\n\n/* Modal */\n.nr-modal {\n  width: min(720px, 100%);\n  background: #111827;           /* dark slate */\n  color: #f9fafb;\n  border: 2px solid rgba(255,255,255,0.12);\n  border-radius: 14px;\n  box-shadow: 0 20px 60px rgba(0,0,0,0.5);\n  overflow: hidden;\n}\n\n/* Header */\n.nr-modal-header {\n  padding: 18px 20px;\n  border-bottom: 1px solid rgba(255,255,255,0.10);\n}\n.nr-modal-title {\n  font-size: 28px;               /* big text */\n  font-weight: 700;\n  letter-spacing: 0.2px;\n}\n\n/* Body */\n.nr-modal-body {\n  padding: 18px 20px 6px 20px;\n}\n.nr-modal-message {\n  font-size: 20px;               /* big message text */\n  line-height: 1.35;\n}\n\n/* Actions */\n.nr-modal-actions {\n  display: flex;\n  gap: 12px;\n  justify-content: flex-end;\n  padding: 16px 20px 20px 20px;\n}\n\n.nr-btn {\n  font-size: 18px;\n  padding: 12px 16px;\n  border-radius: 12px;\n  border: 0;\n  cursor: pointer;\n  min-width: 140px;\n}\n\n.nr-btn-cancel {\n  background: rgba(255,255,255,0.12);\n  color: #f9fafb;\n}\n.nr-btn-cancel:hover {\n  background: rgba(255,255,255,0.18);\n}\n\n.nr-btn-confirm {\n  background: #dc2626;           /* red confirm */\n  color: white;\n}\n.nr-btn-confirm:hover {\n  background: #b91c1c;\n}\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 310,
        "y": 1100,
        "wires": [
            []
        ]
    },
