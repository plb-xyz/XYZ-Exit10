        ]
    },
    {
        "id": "wo2-discover-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Prepare timelines request",
        "func": "// Build the HTTP GET request for /v0/timelines\nconst cfg  = flow.get('watchout_config') || {};\nconst host = cfg.host || 'localhost';\nconst port = cfg.port || 3019;\nmsg.method  = 'GET';\nmsg.url     = 'http://' + host + ':' + port + '/v0/timelines';\nmsg.headers = { 'Content-Type': 'application/json' };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 350,
        "y": 380,
        "wires": [
            [
                "wo2-discover-http"
            ]
        ]
    },
    {
        "id": "wo2-diff-template",
        "type": "ui-template",
        "z": "wo2-tab",
        "group": "20eba16b1f4b5a48",
        "page": "",
        "ui": "",
        "name": "Diff UI",
        "order": 2,
        "width": "0",
        "height": "0",
        "format": "<template>\n  <div style=\"padding:8px; min-height:220px;\">\n    <p v-if=\"!msg\" style=\"color:#aaa\">Waiting for discovery result...</p>\n\n    <div v-else-if=\"msg.payload.status === 'error'\" style=\"color:#f44336\">\n      <strong>Discovery error</strong><br>{{ msg.payload.error }}\n    </div>\n\n    <div v-else-if=\"msg.payload.status === 'discovered' || msg.payload.status === 'diff_ready'\">\n      <strong>\n        {{ (msg.payload.diff && (msg.payload.diff.added?.length || msg.payload.diff.removed?.length || msg.payload.diff.changed?.length))\n            ? 'Changes detected - review before saving'\n            : 'Discovery result' }}\n      </strong>\n\n      <p style=\"margin:6px 0; color:#aaa;\">\n        {{ msg.payload.count ?? 0 }} timelines discovered\n      </p>\n\n      <pre style=\"background:#1b1b2e;color:#e0e0e0;padding:8px;border-radius:4px;font-size:0.85em;max-height:200px;overflow-y:auto\">\n{{ (msg.payload.diffLines && msg.payload.diffLines.length) ? msg.payload.diffLines.join('\\n') : 'No diff lines' }}\n      </pre>\n    </div>\n\n    <div v-else-if=\"msg.payload.status === 'no_changes'\" style=\"color:#4caf50\">\n      <strong>No changes detected</strong>\n      <pre style=\"background:#1b1b2e;color:#e0e0e0;padding:8px;border-radius:4px;font-size:0.85em;max-height:180px;overflow-y:auto\">\n{{ msg.payload.diffLines ? msg.payload.diffLines.join('\\n') : '' }}\n      </pre>\n    </div>\n\n    <div v-else style=\"color:#aaa\">\n      Unknown status: {{ msg.payload.status }}\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {}\n</script>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
        "x": 590,
        "y": 380,
        "wires": [
            [
                "wo2-action-switch"
            ]
        ]
    },
    {
        "id": "wo2-action-switch",
        "type": "switch",
        "z": "wo2-tab",
        "name": "Confirm or Cancel?",
        "property": "payload.action",
        "propertyType": "msg",
        "rules": [
            {
                "t": "eq",
                "v": "confirm",
                "vt": "str"
            },
            {
                "t": "eq",
                "v": "cancel",
                "vt": "str"
            }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 2,
        "x": 570,
        "y": 460,
        "wires": [
            [
                "wo2-confirm-prepare-fn"
            ],
            [
                "wo2-cancel-fn"
            ]
        ]
    },
    {
        "id": "wo2-confirm-prepare-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Prepare mapping write",
        "func": "// Prepare mapping JSON for file write\nconst pending = flow.get('watchout_pending');\nif (!pending) {\n    node.send({ payload: { status: 'nothing_pending' }, topic: 'watchout/confirm' });\n    return null;\n}\n\n// Update flow context immediately\nflow.set('watchout_mapping', pending);\nflow.set('watchout_pending', null);\n\n// Prepare file write\nconst cfg = flow.get('watchout_config') || {};\nmsg.filename = cfg.mappingFile || '/data/projects/XYZ-Exit10/node-red/data/timeline-mapping.json';\nmsg.payload  = JSON.stringify({ mapping: pending, lastSaved: new Date().toISOString() }, null, 2);\nmsg._pendingMapping = pending;\nmsg._savedAt = new Date().toISOString();\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 440,
        "wires": [
            [
                "wo2-write-mapping-file"
            ]
        ]
    },
    {
        "id": "wo2-write-mapping-file",
        "type": "file",
        "z": "wo2-tab",
        "name": "Write timeline-mapping.json",
        "filename": "filename",
        "filenameType": "msg",
        "appendNewline": false,
        "createDir": true,
        "overwriteFile": "true",
        "encoding": "utf8",
        "x": 1030,
        "y": 440,
        "wires": [
            [
                "wo2-confirm-done-fn"
            ]
        ]
    },
    {
        "id": "wo2-confirm-done-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Confirm done",
        "func": "// Confirm & Save completed\nconst mapping = msg._pendingMapping || flow.get('watchout_mapping') || {};\nnode.status({ fill: 'green', shape: 'dot', text: 'Saved: ' + Object.keys(mapping).length + ' timelines' });\nnode.send({\n    payload: {\n        status:  'saved',\n        mapping: mapping,\n        savedAt: msg._savedAt || new Date().toISOString()\n    },\n    topic: 'watchout/confirm'\n});\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1240,
        "y": 440,
        "wires": [
            [
                "wo2-status-template"
            ]
        ]
    },
    {
        "id": "wo2-cancel-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Cancel discovery",
        "func": "// Cancel pending discovery\nflow.set('watchout_pending', null);\nnode.send({ payload: { status: 'cancelled' }, topic: 'watchout/cancel' });\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 520,
        "wires": [
            [
                "wo2-status-template"
            ]
        ]
    },
    {
        "id": "wo2-status-template",
        "type": "ui-template",
        "z": "wo2-tab",
        "group": "20eba16b1f4b5a48",
        "page": "",
        "ui": "",
        "name": "Mapping Status",
        "order": 5,
        "width": "0",
        "height": "0",
        "format": "<template>\n  <div style=\"padding:4px\">\n    <p v-if=\"!msg\" style=\"color:#aaa\">No mapping operation yet.</p>\n    <div v-else-if=\"msg.payload.status === 'saved'\" style=\"color:#4caf50\">\n      <strong>Mapping saved</strong>\n      <p style=\"font-size:0.85em;color:#aaa\">{{ msg.payload.savedAt }}</p>\n      <p><strong>{{ Object.keys(msg.payload.mapping || {}).length }} timelines active:</strong></p>\n      <div v-for=\"(tid, cid) in (msg.payload.mapping || {})\" :key=\"cid\"\n           style=\"font-family:monospace;font-size:0.85em\">\n        <span style=\"color:#80cbc4\">{{ cid }}</span>\n        <span style=\"color:#aaa\"> -&gt; id </span>\n        <span style=\"color:#1e3a8a\">{{ tid }}</span>\n      </div>\n    </div>\n    <div v-else-if=\"msg.payload.status === 'cancelled'\" style=\"color:#ff9800\">\n      Discovery cancelled - mapping unchanged.\n    </div>\n    <div v-else-if=\"msg.payload.status === 'nothing_pending'\" style=\"color:#aaa\">\n      Nothing pending - run discovery first.\n    </div>\n    <div v-else-if=\"msg.payload.status === 'error'\" style=\"color:#f44336\">\n      Save failed: {{ msg.payload.error }}\n    </div>\n  </div>\n</template>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
        "x": 1000,
        "y": 520,
        "wires": [
            []
        ]
    },
    {
        "id": "wo2-control-in",
        "type": "http in",
        "z": "wo2-tab",
        "g": "dbd2c45c3962d1cd",
        "name": "POST /watchout/control",
        "url": "/watchout/control",
        "method": "post",
        "upload": false,
        "swaggerDoc": "",
        "x": 180,
        "y": 660,
        "wires": [
