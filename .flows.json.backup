    {
        "id": "cd9a6261ae15ae21",
        "type": "inject",
        "z": "4427b69f42325844",
        "name": "Init config on deploy",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
