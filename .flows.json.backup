    {
        "id": "1c2eed29583d5845",
        "type": "ui-switch",
        "z": "22f501abaf7e8db6",
        "name": "Atrium 1",
        "label": "Atrium 1",
        "group": "5176b798f54b89e5",
        "order": 4,
        "width": "1",
        "height": "1",
        "passthru": false,
        "decouple": false,
        "topic": "atrium1",
        "topicType": "str",
        "style": "",
        "className": "",
        "layout": "row-left",
