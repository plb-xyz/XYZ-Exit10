            ]
        ]
    },
    {
        "id": "391c22b4831ae5eb",
        "type": "ui-template",
        "z": "19fbd7cf3882c4ad",
        "group": "26c96904b4efbb4b",
        "page": "",
        "ui": "",
        "name": "Satus(es)",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div class=\"status-board\">\n    <!-- SECTION 1 -->\n    <div class=\"section\">\n      <div class=\"section-title\">Exit10 Systems</div>\n\n      <div class=\"system-grid\">\n        <div\n          class=\"system-card\"\n          v-for=\"(sys, idx) in exit10Systems\"\n          :key=\"sys.id\"\n          :class=\"idx % 2 === 0 ? 'alt-a' : 'alt-b'\"\n        >\n          <div class=\"system-title\">{{ sys.title }}</div>\n\n          <div class=\"endpoints\">\n            <div class=\"endpoint\" v-for=\"ep in sys.items\" :key=\"ep.id\">\n              <div class=\"ep-name\">{{ ep.name }}</div>\n\n              <div class=\"ep-indicator\">\n                <span class=\"led\" :class=\"[ledClass(ep.state), blinkClass(ep.state)]\"></span>\n                <span class=\"state-text\">{{ stateText(ep.state) }}</span>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"meta\" v-if=\"sys.meta\">{{ sys.meta }}</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- SECTION 2 -->\n    <div class=\"section\">\n      <div class=\"section-title\">External Systems</div>\n\n      <div class=\"external-grid\">\n        <div\n          class=\"external-card\"\n          v-for=\"(item, idx) in externalItems\"\n          :key=\"item.id\"\n          :class=\"idx % 2 === 0 ? 'alt-a' : 'alt-b'\"\n        >\n          <div class=\"card-top\">\n            <div class=\"name\">{{ item.name }}</div>\n\n            <div class=\"indicator\">\n              <span class=\"led\" :class=\"[ledClass(item.state), blinkClass(item.state)]\"></span>\n              <span class=\"state-text\">{{ stateText(item.state) }}</span>\n            </div>\n          </div>\n\n          <div class=\"meta\" v-if=\"item.meta\">{{ item.meta }}</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      // SECTION 1\n      exit10Systems: [\n        {\n          id: \"sys_watchout\",\n          title: \"Watchout\",\n          items: [\n            { id: \"watchout_main\", name: \"Main\", state: \"disconnected\" },\n            { id: \"watchout_backup\", name: \"Backup\", state: \"disconnected\" },\n          ],\n          meta: \"\",\n        },\n        {\n          id: \"sys_grandma\",\n          title: \"GrandMA\",\n          items: [\n            { id: \"grandma_main\", name: \"Main\", state: \"disconnected\" },\n            { id: \"grandma_backup\", name: \"Backup\", state: \"disconnected\" },\n          ],\n          meta: \"\",\n        },\n        {\n          id: \"sys_qsys\",\n          title: \"Qsys\",\n          items: [\n            { id: \"qsys_main\", name: \"Main\", state: \"disconnected\" },\n            { id: \"qsys_backup\", name: \"Backup\", state: \"disconnected\" },\n          ],\n          meta: \"\",\n        },\n        {\n          id: \"sys_video_h15\",\n          title: \"Video H15\",\n          items: [\n            { id: \"video_h15_main\", name: \"Main\", state: \"disconnected\" },\n            { id: \"video_h15_backup\", name: \"Backup\", state: \"disconnected\" },\n          ],\n          meta: \"\",\n        },\n        {\n          id: \"sys_relays\",\n          title: \"Relay Panels\",\n          items: [\n            { id: \"relay_panel_1\", name: \"Panel 1\", state: \"disconnected\" },\n            { id: \"relay_panel_2\", name: \"Panel 2\", state: \"disconnected\" },\n          ],\n          meta: \"\",\n        },\n      ],\n\n      // SECTION 2\n      externalItems: [\n        { id: \"pharos_main\",            name: \"Pharos Main\",            state: \"disconnected\", meta: \"\" },\n        { id: \"pharos_2\",               name: \"Pharos 2\",               state: \"disconnected\", meta: \"\" },\n        { id: \"pharos_3\",               name: \"Pharos 3\",               state: \"disconnected\", meta: \"\" },\n        { id: \"cinema_dome_brightsign\", name: \"Cinema Dome Brightsign\", state: \"disconnected\", meta: \"\" },\n        { id: \"cinema_led_columns\",     name: \"Cinema LED columns\",     state: \"disconnected\", meta: \"\" },\n        { id: \"water_feature_1\",        name: \"Water Feature 1\",        state: \"disconnected\", meta: \"\" },\n        { id: \"water_feature_2\",        name: \"Water Feature 2\",        state: \"disconnected\", meta: \"\" },\n        { id: \"water_feature_3\",        name: \"Water Feature 3\",        state: \"disconnected\", meta: \"\" },\n      ],\n    };\n  },\n\n  methods: {\n    ledClass(state) {\n      if (state === \"connected\") return \"led-green\";\n      if (state === \"connecting\") return \"led-amber\";\n      return \"led-red\"; // disconnected + error\n    },\n    blinkClass(state) {\n      if (state === \"error\") return \"blink-fast\";\n      if (state === \"connecting\") return \"blink-slow\";\n      return \"\";\n    },\n    stateText(state) {\n      if (state === \"connected\") return \"Connected\";\n      if (state === \"connecting\") return \"Connecting…\";\n      if (state === \"error\") return \"Error\";\n      return \"Disconnected\";\n    },\n\n    findEndpointById(id) {\n      for (const sys of this.exit10Systems) {\n        const ep = sys.items.find((x) => x.id === id);\n        if (ep) return ep;\n      }\n      const ext = this.externalItems.find((x) => x.id === id);\n      if (ext) return ext;\n      return null;\n    },\n\n    setItem(id, patch) {\n      const item = this.findEndpointById(id);\n      if (!item) return false;\n\n      if (patch.state) item.state = patch.state;\n      if (typeof patch.meta === \"string\") item.meta = patch.meta; // external only\n      if (typeof patch.name === \"string\") item.name = patch.name;\n      return true;\n    },\n\n    applyMsg(msg) {\n      const p = msg?.payload;\n      if (!p) return;\n\n      // single update: { id, state, meta }\n      if (typeof p === \"object\" && p.id) {\n        this.setItem(p.id, p);\n        return;\n      }\n\n      // bulk update: { id1: \"connected\", id2: {state, meta}, ... }\n      if (typeof p === \"object\") {\n        for (const [id, val] of Object.entries(p)) {\n          if (val && typeof val === \"object\") this.setItem(id, val);\n          else if (typeof val === \"string\") this.setItem(id, { state: val });\n        }\n      }\n    },\n  },\n\n  mounted() {\n    this.$watch(\n      () => this.msg,\n      (msg) => this.applyMsg(msg),\n      { deep: true, immediate: true }\n    );\n  },\n};\n</script>\n\n<style>\n/* Overall */\n.status-board {\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n}\n\n.section {\n  padding: 12px;\n  border-radius: 14px;\n  background: rgba(0,0,0,0.035);\n}\n\n.section-title {\n  font-size: 22px;     /* bigger titles */\n  font-weight: 950;\n  letter-spacing: 0.2px;\n  margin: 4px 0 10px 2px;\n}\n\n/* Cards: 2-up when space allows; 1-up on small screens */\n.system-grid,\n.external-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(280px, 1fr));\n  gap: 10px;           /* tighter spacing between cards */\n}\n\n@media (max-width: 820px) {\n  .system-grid,\n  .external-grid {\n    grid-template-columns: 1fr;  /* only side-by-side when width allows */\n  }\n}\n\n/* Alternating light purple tint to differentiate cards */\n.alt-a {\n  background: rgba(255,255,255,0.68);\n}\n.alt-b {\n  background: rgba(152, 92, 255, 0.07); /* light purple */\n}\n\n/* System card */\n.system-card,\n.external-card {\n  padding: 10px 10px;     /* smaller card */\n  border-radius: 16px;\n  box-shadow: 0 1px 0 rgba(0,0,0,0.04);\n}\n\n.system-title {\n  font-size: 18px;        /* focus on title */\n  font-weight: 900;\n  margin: 2px 0 8px 2px;\n}\n\n/* Endpoints inside system card */\n.endpoints {\n  display: flex;\n  flex-direction: column;\n  gap: 6px;               /* reduced spacing between Main/Backup */\n}\n\n.endpoint {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 10px;\n  padding: 9px 10px;      /* smaller endpoint rows */\n  border-radius: 14px;\n  background: rgba(255,255,255,0.55);\n}\n\n.ep-name {\n  font-size: 14px;        /* smaller + not bold */\n  font-weight: 500;\n  opacity: 0.9;\n}\n\n.ep-indicator,\n.indicator {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  flex-shrink: 0;\n}\n\n.state-text {\n  font-size: 14px;        /* smaller */\n  font-weight: 700;\n}\n\n/* External card top */\n.card-top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 10px;\n}\n\n.name {\n  font-size: 14px;\n  font-weight: 700;\n  min-width: 0;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.meta {\n  margin-top: 6px;\n  font-size: 12px;\n  opacity: 0.75;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n/* LED */\n.led {\n  width: 14px;\n  height: 14px;\n  border-radius: 999px;\n  box-shadow: inset 0 0 0 2px rgba(255,255,255,0.22),\n              0 0 0 2px rgba(0,0,0,0.10);\n}\n\n.led-green { background: #22c55e; box-shadow: 0 0 12px rgba(34,197,94,0.50), inset 0 0 0 2px rgba(255,255,255,0.22), 0 0 0 2px rgba(0,0,0,0.10); }\n.led-amber { background: #f59e0b; box-shadow: 0 0 12px rgba(245,158,11,0.50), inset 0 0 0 2px rgba(255,255,255,0.22), 0 0 0 2px rgba(0,0,0,0.10); }\n.led-red   { background: #ef4444; box-shadow: 0 0 12px rgba(239,68,68,0.50), inset 0 0 0 2px rgba(255,255,255,0.22), 0 0 0 2px rgba(0,0,0,0.10); }\n\n/* Blink */\n.blink-slow { animation: blink 0.9s infinite ease-in-out; }\n.blink-fast { animation: blink 0.35s infinite ease-in-out; }\n@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.15; } }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 440,
        "y": 440,
