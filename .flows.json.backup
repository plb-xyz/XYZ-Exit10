    {
        "id": "wo2-sse-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Configure SSE URL",
        "func": "// Build the SSE endpoint URL from flow config and trigger the SSE client\nconst cfg  = flow.get('watchout_config') || {};\nconst host = cfg.host || 'host.docker.internal';\nconst port = cfg.port || 3019;\nmsg.url     = 'http://' + host + ':' + port + '/v1/sse';\nmsg.headers = { 'Accept': 'text/event-stream', 'Cache-Control': 'no-cache' };\nflow.set('watchout_sse_status', 'connecting');\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
