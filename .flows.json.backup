    {
        "id": "wo2-poll-parse-fn",
        "type": "function",
        "z": "wo2-tab",
        "name": "Parse poll response",
        "func": "// Handle the GET /v0/state poll response\nconst statusCode = msg.statusCode || 200;\nif (statusCode !== 200) {\n    node.warn('[Watchout Poll] HTTP ' + statusCode);\n    return null;\n}\n\nconst state = msg.payload;\nflow.set('watchout_state', state);\n\nnode.send({ payload: { type: 'poll', data: state }, topic: 'watchout/state' });\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 940,
        "wires": [
            [
                "wo2-state-template"
            ]
        ]
    },
