        "name": "OSC Encode (/cmd,s,…)",
        "func": "'use strict';\n// OSC binary encode: /cmd ,s <payload string>\nvar cmdString = msg.payload;\nfunction oscString(str) {\n    var len = Buffer.byteLength(str, 'utf8') + 1;\n    var padded = Math.ceil(len / 4) * 4;\n    var buf = Buffer.alloc(padded, 0);\n    buf.write(str, 0, 'utf8');\n    return buf;\n}\nmsg.payload = Buffer.concat([oscString('/cmd'), oscString(',s'), oscString(cmdString)]);\nreturn msg;",
